{
  "name": "@pi-postbox/extension",
  "version": "0.1.0",
  "description": "Pi extension that registers sessions with Pi Postbox and exposes ask_postbox.",
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "package.json",
    "README.md"
  ],
  "keywords": [
    "pi",
    "extension",
    "postbox",
    "ask_postbox"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dasomji/pi-postbox.git",
    "directory": "packages/extension"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@pi-postbox/protocol": "0.1.0",
    "typebox": "^1.1.38",
    "ws": "^8.21.0"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  }
}
