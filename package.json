{
  "name": "@wienerberliner/pi-postbox",
  "version": "0.1.0",
  "description": "Pi Postbox extension and web service for remote human decision handoffs.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build -w @pi-postbox/web && node scripts/copy-web-to-server.mjs",
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "smoke": "node scripts/smoke-postbox.mjs",
    "prepack": "npm run build"
  },
  "bin": {
    "pi-postbox-server": "./packages/server/dist/cli.js"
  },
  "files": [
    "README.md",
    "packages/extension/package.json",
    "packages/extension/src",
    "packages/protocol/package.json",
    "packages/protocol/dist",
    "packages/server/package.json",
    "packages/server/dist"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "postbox",
    "dashboard",
    "tailscale"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./packages/extension/src/index.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@pi-postbox/protocol": "file:packages/protocol",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.2.1",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "bundledDependencies": [
    "@pi-postbox/protocol"
  ]
}
